{
  "version": 2,
  "name": "hellogen",
  "public": true,
  "outputDirectory": "frontend",
  "builds": [
    {
      "src": "frontend/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/style.css",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/script.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}